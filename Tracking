      <button style={btn} onClick={()=>setAdding(!adding)}>+ Agregar</button>
    </div>
    {adding&&<div style={{...card,border:`1px solid ${C.gold}44`}}>
      <div style={{fontSize:13,fontWeight:700,color:C.gold,marginBottom:12}}>Registrar feedback</div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:10}}>
        <div><label style={lbl}>Fecha</label><input type="date" style={inp} value={form.date} onChange={e=>setForm(f=>({...f,date:e.target.value}))}/></div>
        <div><label style={lbl}>Quién lo dio</label><input style={inp} value={form.from} onChange={e=>setForm(f=>({...f,from:e.target.value}))} placeholder="Nombre"/></div>
      </div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:10}}>
        <div><label style={lbl}>Fase</label><select style={inp} value={form.phase} onChange={e=>setForm(f=>({...f,phase:Number(e.target.value)}))}>{[1,2,3].map(ph=><option key={ph} value={ph}>{PM[ph].label}</option>)}</select></div>
        <div><label style={lbl}>Tipo</label><select style={inp} value={form.type} onChange={e=>setForm(f=>({...f,type:e.target.value}))}><option value="positivo">Positivo</option><option value="desarrollo">Desarrollo</option><option value="critico">Crítico</option></select></div>
      </div>
      <div style={{marginBottom:10}}><label style={lbl}>Contenido del feedback</label><textarea style={ta} value={form.content} onChange={e=>setForm(f=>({...f,content:e.target.value}))} placeholder="¿Qué te dijeron exactamente?"/></div>
      <div style={{marginBottom:14}}><label style={lbl}>¿Qué voy a hacer con esto?</label><textarea style={{...ta,minHeight:52}} value={form.action} onChange={e=>setForm(f=>({...f,action:e.target.value}))} placeholder="Acción concreta..."/></div>
      <div style={{display:"flex",gap:10}}><button style={btn} onClick={add}>Guardar</button><button style={btnSm} onClick={()=>setAdding(false)}>Cancelar</button></div>
    </div>}
    {log.length===0&&!adding&&<div style={{...card,textAlign:"center",padding:48}}><div style={{fontSize:36,marginBottom:10}}>💬</div><div style={{color:C.muted,fontSize:13}}>Sin feedback registrado.<br/>Cada comentario del liderazgo son datos.</div></div>}
    {log.map(fb=>{const m=PM[fb.phase]||PM[1];return<div key={fb.id} style={{...card,borderLeft:`3px solid ${m.color}`}}>
      <div style={{display:"flex",justifyContent:"space-between",marginBottom:8}}>
        <div style={{display:"flex",gap:8,flexWrap:"wrap",alignItems:"center"}}><PChip phase={fb.phase}/><Pill color={tc[fb.type]}>{tl[fb.type]}</Pill>{fb.from&&<span style={{fontSize:12,fontWeight:600}}>{fb.from}</span>}{fb.date&&<span style={{fontSize:11,color:C.muted}}>{fb.date}</span>}</div>
        <button onClick={()=>rem(fb.id)} style={{background:"none",border:"none",color:C.muted,cursor:"pointer",fontSize:16}}>×</button>
      </div>
      <div style={{fontSize:13,color:C.text,lineHeight:1.55,marginBottom:fb.action?10:0}}>{fb.content}</div>
      {fb.action&&<div style={{background:C.surface,borderRadius:8,padding:"8px 10px"}}><div style={{fontSize:10,color:C.muted,textTransform:"uppercase",letterSpacing:"1px",marginBottom:3}}>Mi acción</div><div style={{fontSize:12,color:C.mutedLight}}>{fb.action}</div></div>}
    </div>})}
  </div>;
}

