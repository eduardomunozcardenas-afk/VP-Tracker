  const rem=(id)=>setData(d=>({...d,feedbackLog:d.feedbackLog.filter(f=>f.id!==id)}));
  const log=data.feedbackLog||[];
  const tc={positivo:"green",desarrollo:"gold",critico:"purple"};
  const tl={positivo:"✦ Positivo",desarrollo:"◈ Desarrollo",critico:"▲ Crítico"};
  return<div>
    <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:18}}>
