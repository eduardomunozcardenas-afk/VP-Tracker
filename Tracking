  const pa=(ph)=>{const a=data.actions.filter(x=>x.phase===ph);const d=a.filter(x=>x.done).length;return{total:a.length,done:d,pct:a.length?Math.round(d/a.length*100):0}};
  const done=data.actions.filter(a=>a.done).length;
  return<div>
    <div style={{marginBottom:24}}>
      <div style={{fontSize:24,fontWeight:900,letterSpacing:"-1.5px",lineHeight:1.1,marginBottom:6}}>Tu camino a <span style={{color:C.purple}}>VP</span> en Visa</div>
      <div style={{color:C.muted,fontSize:13}}>Director · Sr. Director · Vice President</div>
    </div>
    <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:10,marginBottom:18}}>
      {[1,2,3].map(ph=>{const m=PM[ph];const p=pa(ph);const cur=data.currentPhase===ph;return<div key={ph} style={{...card,margin:0,border:cur?`1px solid ${m.color}55`:`1px solid ${C.border}`,background:cur?`linear-gradient(135deg,${m.bg},${C.card})`:C.card,position:"relative"}}>
        {cur&&<div style={{position:"absolute",top:8,right:8,fontSize:8,fontWeight:700,color:m.color,letterSpacing:"1px"}}>ACTUAL</div>}
        <div style={{fontSize:20,marginBottom:6}}>{m.icon}</div>
        <div style={{fontSize:13,fontWeight:800,color:m.color,marginBottom:2}}>{m.label}</div>
        <div style={{fontSize:10,color:C.muted,marginBottom:10}}>{m.sublabel}</div>
        <PBar value={p.pct} color={m.color}/>
        <div style={{fontSize:10,color:C.muted,marginTop:4}}>{p.done}/{p.total}</div>
      </div>})}
    </div>
    <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:18}}>
      {[
        {n:done,total:data.actions.length,label:"Acciones completadas",color:C.accent},
        {n:(data.visibilityLog||[]).length,label:"Momentos visibilidad",color:C.purple},
        {n:(data.stakeholders||[]).filter(s=>s.name).length,label:"Stakeholders mapeados",color:C.gold},
        {n:(data.feedbackLog||[]).length,label:"Feedbacks recibidos",color:C.mutedLight},
      ].map((s,i)=><div key={i} style={{background:C.surface,border:`1px solid ${C.border}`,borderRadius:12,padding:"14px 16px"}}>
        <div style={{fontSize:26,fontWeight:900,letterSpacing:"-2px",color:s.color,lineHeight:1}}>{s.n}{s.total?<span style={{fontSize:12,color:C.muted,fontWeight:400}}>/{s.total}</span>:""}</div>
        <div style={{fontSize:10,color:C.muted,marginTop:4,letterSpacing:"0.5px",textTransform:"uppercase"}}>{s.label}</div>
      </div>)}
    </div>
    <div style={card}>
      <div style={{fontSize:11,color:C.muted,letterSpacing:"1.5px",textTransform:"uppercase",marginBottom:12}}>Fase actual</div>
      <div style={{display:"flex",gap:8}}>
        {[1,2,3].map(ph=>{const m=PM[ph];const a=data.currentPhase===ph;return<button key={ph} onClick={()=>setData(d=>({...d,currentPhase:ph}))} style={{flex:1,padding:"10px 6px",border:`1px solid ${a?m.color:C.border}`,borderRadius:10,background:a?m.bg:"transparent",color:a?m.color:C.muted,fontFamily:"inherit",fontWeight:700,fontSize:12,cursor:"pointer"}}>{m.icon}<br/>{m.label}</button>})}
      </div>
    </div>
    <div style={{...card,borderLeft:`3px solid ${C.accent}`}}>
      <div style={{fontSize:13,fontStyle:"italic",color:C.text,lineHeight:1.7}}>"La visibilidad no es sobre aparecer más. Es sobre ser recordado por algo específico cada vez que apareces."</div>
    </div>
  </div>;
}

function Skills({data,setData}){
  const[active,setActive]=useState(SKILLS[0].id);
  const sk=SKILLS.find(s=>s.id===active);
  const sd=data.skills[active]||{p1:0,p2:0,p3:0,notes:""};
  const upd=(f,v)=>setData(d=>({...d,skills:{...d.skills,[active]:{...d.skills[active],[f]:v}}}));
  return<div>
    <div style={{marginBottom:18}}><div style={{fontSize:22,fontWeight:800,letterSpacing:"-0.5px"}}>Skills por Etapa</div><div style={{color:C.muted,fontSize:13,marginTop:4}}>Autoevalúa tu nivel en cada competencia</div></div>
    <div style={{display:"flex",gap:8,flexWrap:"wrap",marginBottom:16}}>
      {SKILLS.map(s=><button key={s.id} onClick={()=>setActive(s.id)} style={{padding:"7px 12px",border:`1px solid ${active===s.id?C.accent:C.border}`,borderRadius:8,background:active===s.id?C.accentGlow:"transparent",color:active===s.id?C.accent:C.muted,fontFamily:"inherit",fontSize:12,cursor:"pointer",fontWeight:active===s.id?700:400}}>{s.icon} {s.label}</button>)}
    </div>
    {[1,2,3].map(ph=>{
      const m=PM[ph];const pi=sk.phases[ph];const sk2=`p${ph}`;const score=sd[sk2]||0;
      return<div key={ph} style={{...card,borderLeft:`3px solid ${m.color}`}}>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",marginBottom:12}}>
          <div><PChip phase={ph} size="lg"/><div style={{fontSize:13,fontWeight:600,marginTop:8,color:C.text}}>{pi.goal}</div></div>
          <div style={{fontSize:24,fontWeight:900,color:m.color,letterSpacing:"-1px",lineHeight:1,flexShrink:0,marginLeft:12}}>{score}<span style={{fontSize:11,color:C.muted}}>/5</span></div>
        </div>
        <div style={{marginBottom:12}}>
          {pi.b.map((b,i)=><div key={i} style={{display:"flex",gap:8,alignItems:"flex-start",padding:"5px 0",borderBottom:i<pi.b.length-1?`1px solid ${C.border}`:"none"}}>
            <div style={{width:5,height:5,borderRadius:"50%",background:m.color,flexShrink:0,marginTop:7}}/>
            <div style={{fontSize:12,color:C.mutedLight,lineHeight:1.5}}>{b}</div>
          </div>)}
        </div>
        <div style={{display:"flex",gap:6}}>
          {[0,1,2,3,4,5].map(n=><button key={n} onClick={()=>upd(sk2,n)} style={{flex:1,height:34,border:`1px solid ${score>=n&&n>0?m.color:C.border}`,borderRadius:7,background:score>=n&&n>0?m.bg:"transparent",color:score>=n&&n>0?m.color:C.muted,fontFamily:"inherit",fontSize:13,fontWeight:700,cursor:"pointer"}}>{n}</button>)}
        </div>
      </div>;
    })}
    <div style={card}><label style={lbl}>Notas sobre este skill</label><textarea style={ta} value={sd.notes||""} onChange={e=>upd("notes",e.target.value)} placeholder="Reflexiones, feedback recibido, oportunidades de práctica..."/></div>
  </div>;
}

function Actions({data,setData}){
  const[fp,setFp]=useState(data.currentPhase||1);
  const[exp,setExp]=useState(null);
  const toggle=(id)=>setData(d=>({...d,actions:d.actions.map(a=>a.id===id?{...a,done:!a.done}:a)}));
  const upd=(id,v)=>setData(d=>({...d,actions:d.actions.map(a=>a.id===id?{...a,notes:v}:a)}));
  const fil=data.actions.filter(a=>a.phase===fp);
  const done=fil.filter(a=>a.done).length;
  const m=PM[fp];
  return<div>
    <div style={{marginBottom:18}}><div style={{fontSize:22,fontWeight:800,letterSpacing:"-0.5px"}}>Acciones por Fase</div><div style={{color:C.muted,fontSize:13,marginTop:4}}>Cada acción te acerca al siguiente nivel</div></div>
    <div style={{display:"flex",gap:8,marginBottom:16}}>
      {[1,2,3].map(ph=>{const pm=PM[ph];const pa=data.actions.filter(a=>a.phase===ph);const pd=pa.filter(a=>a.done).length;return<button key={ph} onClick={()=>setFp(ph)} style={{flex:1,padding:"9px 6px",border:`1px solid ${fp===ph?pm.color:C.border}`,borderRadius:10,background:fp===ph?pm.bg:"transparent",color:fp===ph?pm.color:C.muted,fontFamily:"inherit",fontSize:12,cursor:"pointer",fontWeight:fp===ph?700:400}}>{pm.icon} {pm.label}<div style={{fontSize:10,marginTop:2,opacity:0.7}}>{pd}/{pa.length}</div></button>})}
    </div>
    <div style={{...card,marginBottom:14}}>
      <div style={{display:"flex",justifyContent:"space-between",marginBottom:6}}><span style={{fontSize:13,fontWeight:600}}>{done}/{fil.length} completadas</span><span style={{fontSize:13,color:m.color,fontWeight:700}}>{fil.length?Math.round(done/fil.length*100):0}%</span></div>
      <PBar value={fil.length?Math.round(done/fil.length*100):0} color={m.color} h={8}/>
    </div>
    <div style={card}>
      {fil.map((a,i)=><div key={a.id} style={{borderBottom:i<fil.length-1?`1px solid ${C.border}`:"none",padding:"13px 0"}}>
        <div style={{display:"flex",gap:12,alignItems:"flex-start"}}>
          <CB checked={a.done} onChange={()=>toggle(a.id)} color={m.color}/>
          <div style={{flex:1}}>
            <div style={{display:"flex",justifyContent:"space-between",gap:8,alignItems:"flex-start"}}>
              <div style={{fontSize:13,color:a.done?C.muted:C.text,textDecoration:a.done?"line-through":"none",lineHeight:1.45}}>{a.text}</div>
              <Pill color={fp===1?"green":fp===2?"gold":"purple"}>{a.week}</Pill>
            </div>
            <button onClick={()=>setExp(exp===a.id?null:a.id)} style={{background:"none",border:"none",color:C.muted,fontSize:11,cursor:"pointer",padding:"3px 0 0",fontFamily:"inherit"}}>{exp===a.id?"▲ ocultar":"▼ notas"}</button>
            {exp===a.id&&<textarea style={{...ta,marginTop:8}} value={a.notes} onChange={e=>upd(a.id,e.target.value)} placeholder="Resultados, reflexiones, próximos pasos..."/>}
          </div>
        </div>
      </div>)}
    </div>
  </div>;
}

