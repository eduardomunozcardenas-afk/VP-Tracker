        <button onClick={()=>rem(v.id)} style={{background:"none",border:"none",color:C.muted,cursor:"pointer",fontSize:16}}>×</button>
      </div>
      <div style={{fontSize:13,color:C.text,lineHeight:1.55,marginBottom:(v.impact||v.nextStep)?10:0}}>{v.what}</div>
      {(v.impact||v.nextStep)&&<div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10}}>
        {v.impact&&<div style={{background:C.surface,borderRadius:8,padding:"8px 10px"}}><div style={{fontSize:10,color:C.muted,textTransform:"uppercase",letterSpacing:"1px",marginBottom:3}}>Impacto</div><div style={{fontSize:12,color:C.mutedLight}}>{v.impact}</div></div>}
        {v.nextStep&&<div style={{background:C.surface,borderRadius:8,padding:"8px 10px"}}><div style={{fontSize:10,color:C.muted,textTransform:"uppercase",letterSpacing:"1px",marginBottom:3}}>Próximo paso</div><div style={{fontSize:12,color:C.mutedLight}}>{v.nextStep}</div></div>}
      </div>}
    </div>})}
  </div>;
}

function Feedback({data,setData}){
