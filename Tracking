function useSt(key,init){
  const [v,sv]=useState(()=>{try{const s=localStorage.getItem(key);return s?{...init,...JSON.parse(s)}:init}catch{return init}});
  useEffect(()=>{try{localStorage.setItem(key,JSON.stringify(v))}catch{}},[key,v]);
  return[v,sv];
}

const inp={background:"#090D18",border:`1px solid ${C.border}`,borderRadius:8,color:C.text,fontFamily:"inherit",fontSize:13,padding:"9px 13px",width:"100%",boxSizing:"border-box",outline:"none"};
